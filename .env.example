# Copy this file to .env and change values for your environment.
SECRET_KEY=change-me-to-a-long-random-value
DATABASE_URL=sqlite:///instance/library.sqlite3

# Student borrowing options.
STUDENT_LOAN_DAYS=14

# DeepFace options. Facenet is a reasonable speed/accuracy tradeoff for a demo.
DEEPFACE_MODEL=Facenet
DEEPFACE_DETECTOR_BACKEND=opencv
DEEPFACE_DISTANCE_METRIC=cosine
